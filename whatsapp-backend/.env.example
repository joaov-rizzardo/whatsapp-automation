NODE_ENV=development
PORT=3333
HOST=0.0.0.0

DATABASE_URL="postgresql://whatsapp:whatsapp@localhost:5432/whatsapp_automation?schema=public"
REDIS_URL="redis://localhost:6379"

# gerar com: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3333
CLIENT_ORIGIN=http://localhost:3000

# Google Cloud Console > APIs & Services > Credentials > OAuth client ID (Web application)
# Authorized redirect URI: http://localhost:3333/api/auth/callback/google
# Vazio = so e-mail/senha; o provider do Google so e registrado quando os dois estao preenchidos.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Evolution API (WhatsApp). EVOLUTION_API_KEY must match the value in the root .env.
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
# amqp:// connection string; the backend runs on the host, so localhost.
RABBITMQ_URL=amqp://whatsapp:whatsapp@localhost:5672
RABBITMQ_EVOLUTION_EXCHANGE=evolution
